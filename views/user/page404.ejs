<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found</title>
    <style>
        :root {
    --laptop-color: #333;
    --screen-color: #1a1a1a;
}

body {
    font-family: 'Press Start 2P', Arial, sans-serif;
    text-align: center;
    padding: 20px;
    background-color: #f0f0f0;
    margin: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
}

.container {
    max-width: 800px;
    margin: 0 auto;
}

h1 {
    font-size: 50px;
    margin: 0;
    color: #333;
}

p {
    font-size: 18px;
    color: #666;
    margin: 10px 0;
}

a {
    color: #007BFF;
    text-decoration: none;
}

a:hover {
    text-decoration: underline;
}

.laptop {
    width: 80%;
    max-width: 600px;
    margin: 40px auto;
    transition: transform 0.5s ease;
}

.laptop.fullscreen {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1.5);
    z-index: 1000;
}

.laptop-screen {
    background: var(--screen-color);
    aspect-ratio: 16/10;
    border-radius: 10px 10px 0 0;
    padding: 20px;
    position: relative;
    overflow: hidden;
}

.laptop-base {
    background: var(--laptop-color);
    height: 20px;
    border-radius: 0 0 10px 10px;
    position: relative;
}

.laptop-trackpad {
    width: 30%;
    height: 4px;
    background: #444;
    margin: 0 auto;
    border-radius: 2px;
}

#game-container {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    background: #000;
}

#gameCanvas {
    width: 100%;
    height: 100%;
    display: block;
}

#score {
    position: absolute;
    top: 10px;
    right: 10px;
    color: white;
    font-family: 'Press Start 2P', monospace;
    font-size: 14px;
}

#start-screen {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
}

#playButton {
    background: #007BFF;
    color: white;
    border: none;
    padding: 15px 30px;
    font-size: 18px;
    cursor: pointer;
    border-radius: 5px;
    font-family: 'Press Start 2P', monospace;
    transition: transform 0.2s;
}

#playButton:hover {
    transform: scale(1.1);
}

.hidden {
    display: none;
}

@media (max-width: 768px) {
    .laptop {
        width: 95%;
    }
    
    h1 {
        font-size: 40px;
    }
    
    p {
        font-size: 16px;
    }
}
    </style>
</head>
<body>
    <div class="container">
        <h1>404</h1>
        <p>Page Not Found</p>
        <p>Sorry, the page you are looking for does not exist.</p>
        
        <div class="laptop">
            <div class="laptop-screen">
                <div id="game-container" class="hidden">
                    <canvas id="gameCanvas"></canvas>
                    <div id="score">Score: 0</div>
                </div>
                <div id="start-screen">
                    <button id="playButton">PLAY GAME</button>
                </div>
            </div>
            <div class="laptop-base">
                <div class="laptop-trackpad"></div>
            </div>
        </div>

        <p><a href="/">Go to Homepage</a></p>
    </div>
    <script>
        const playButton = document.getElementById('playButton');
const gameContainer = document.getElementById('game-container');
const startScreen = document.getElementById('start-screen');
const laptop = document.querySelector('.laptop');
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const scoreElement = document.getElementById('score');

let snake = [];
let food = {};
let direction = 'right';
let score = 0;
let gameLoop;
const gridSize = 20;
let gameStarted = false;

function initGame() {
    // Set canvas size
    canvas.width = gameContainer.offsetWidth;
    canvas.height = gameContainer.offsetHeight;
    
    // Initialize snake
    snake = [
        { x: 3, y: 1 },
        { x: 2, y: 1 },
        { x: 1, y: 1 }
    ];
    
    // Create initial food
    createFood();
    
    // Reset score
    score = 0;
    updateScore();
}

function createFood() {
    const maxX = Math.floor(canvas.width / gridSize) - 1;
    const maxY = Math.floor(canvas.height / gridSize) - 1;
    
    food = {
        x: Math.floor(Math.random() * maxX),
        y: Math.floor(Math.random() * maxY)
    };
}

function updateScore() {
    scoreElement.textContent = `Score: ${score}`;
}

function draw() {
    // Clear canvas
    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    // Draw snake
    ctx.fillStyle = '#00ff00';
    snake.forEach(segment => {
        ctx.fillRect(
            segment.x * gridSize,
            segment.y * gridSize,
            gridSize - 2,
            gridSize - 2
        );
    });
    
    // Draw food
    ctx.fillStyle = '#ff0000';
    ctx.fillRect(
        food.x * gridSize,
        food.y * gridSize,
        gridSize - 2,
        gridSize - 2
    );
}

function moveSnake() {
    const head = { ...snake[0] };
    
    switch(direction) {
        case 'up': head.y--; break;
        case 'down': head.y++; break;
        case 'left': head.x--; break;
        case 'right': head.x++; break;
    }
    
    // Check collision with walls
    if (head.x < 0 || 
        head.x >= canvas.width / gridSize ||
        head.y < 0 || 
        head.y >= canvas.height / gridSize) {
        gameOver();
        return;
    }
    
    // Check collision with self
    if (snake.some(segment => segment.x === head.x && segment.y === head.y)) {
        gameOver();
        return;
    }
    
    snake.unshift(head);
    
    // Check if food is eaten
    if (head.x === food.x && head.y === food.y) {
        score += 10;
        updateScore();
        createFood();
    } else {
        snake.pop();
    }
}

function gameOver() {
    clearInterval(gameLoop);
    alert(`Game Over! Score: ${score}`);
    gameStarted = false;
    startScreen.classList.remove('hidden');
    gameContainer.classList.add('hidden');
    laptop.classList.remove('fullscreen');
}

function startGame() {
    if (!gameStarted) {
        gameStarted = true;
        startScreen.classList.add('hidden');
        gameContainer.classList.remove('hidden');
        laptop.classList.add('fullscreen');
        initGame();
        gameLoop = setInterval(() => {
            moveSnake();
            draw();
        }, 100);
    }
}

// Event listeners
playButton.addEventListener('click', startGame);

document.addEventListener('keydown', (e) => {
    if (!gameStarted) return;
    
    switch(e.key) {
        case 'ArrowUp':
            if (direction !== 'down') direction = 'up';
            break;
        case 'ArrowDown':
            if (direction !== 'up') direction = 'down';
            break;
        case 'ArrowLeft':
            if (direction !== 'right') direction = 'left';
            break;
        case 'ArrowRight':
            if (direction !== 'left') direction = 'right';
            break;
    }
});

// Handle window resize
window.addEventListener('resize', () => {
    if (gameStarted) {
        canvas.width = gameContainer.offsetWidth;
        canvas.height = gameContainer.offsetHeight;
        draw();
    }
});
    </script>
</body>
</html>