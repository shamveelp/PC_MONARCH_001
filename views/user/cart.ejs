
<%- include("../../views/partials/user/header") %>

<style>
    .cart-totals-container {
        width: 100%;
        max-width: 400px;
        padding: 16px;
        margin: 0 auto;
    }
    .cart-totals-container h2 {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 16px;
    }
    .cart-totals-container hr {
        margin-bottom: 16px;
    }
    .cart-totals-container .flex {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }
    .cart-totals-container .font-semibold {
        font-weight: 600;
    }
    .cart-totals-container .text-blue {
        color: blue;
    }
    .cart-totals-container .text-sm {
        font-size: 0.875rem;
    }
    .cart-totals-container .bg-yellow {
        background-color: #fbbf24;
    }
    .cart-totals-container .text-white {
        color: white;
    }
    .cart-totals-container .py-2 {
        padding-top: 8px;
        padding-bottom: 8px;
    }
    .cart-totals-container .rounded {
        border-radius: 4px;
    }
    .cart-totals-container .mb-4 {
        margin-bottom: 16px;
    }
    .cart-totals-container .block {
        display: block;
    }
    .cart-totals-container .text-center {
        text-align: center;
    }
    .cart-totals-container .apply-coupon-btn {
            padding: 8px 16px;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        /* General container and section styling */
@media (max-width: 1200px) {
    .container {
        padding: 0 15px;
    }
}

@media (max-width: 991px) {
    .row {
        flex-direction: column;
    }
    .col-9, .col-3 {
        width: 100%;
        max-width: 100%;
    }
    .col-9 {
        margin-bottom: 30px;
    }
}

/* Table responsiveness */
@media (max-width: 767px) {
    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .shopping-summery {
        min-width: 600px;
    }

    .shopping-summery th, .shopping-summery td {
        padding: 10px;
        font-size: 14px;
    }

    .product-name h5 {
        font-size: 16px;
    }

    .detail-qty .quantity-control {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .quantity-input {
        width: 35px !important;
    }

    .increment-button, .decrement-button {
        padding: 5px 10px;
    }
}

@media (max-width: 576px) {
    .shopping-summery {
        display: block;
        min-width: unset;
    }

    .shopping-summery thead {
        display: none; /* Hide table headers */
    }

    .shopping-summery tbody tr {
        display: block;
        margin-bottom: 20px;
        border: 1px solid #ddd;
        padding: 10px;
    }

    .shopping-summery tbody td {
        display: block;
        text-align: left;
        padding: 8px 0;
        border: none;
        position: relative; /* For better positioning */
    }

    /* Ensure data-title is applied correctly */
    .shopping-summery tbody td::before {
        content: attr(data-title) ": ";
        font-weight: bold;
        display: inline-block;
        width: 80px; /* Adjusted width for better spacing */
        vertical-align: top;
    }

    /* Specific styling for Image column */
    .shopping-summery .image {
        display: flex;
        align-items: center;
        padding: 10px 0;
    }

    .shopping-summery .image::before {
        content: "Image: "; /* Explicitly set label */
        font-weight: bold;
        width: 80px;
        flex-shrink: 0;
    }

    .shopping-summery .image img {
        max-width: 80px; /* Smaller image for mobile */
        height: auto;
        display: block;
    }

    /* Specific styling for Name column */
    .shopping-summery .product-des {
        padding: 10px 0;
    }

    .shopping-summery .product-des::before {
        content: "Name: "; /* Explicitly set label */
        font-weight: bold;
        width: 80px;
        display: inline-block;
    }

    .shopping-summery .product-des h5 {
        display: inline; /* Keep name inline with label */
        margin: 0;
    }

    .shopping-summery .product-des p {
        margin: 5px 0 0 80px; /* Align category/brand under name */
        font-size: 12px;
    }

    /* Ensure other columns remain visible */
    .shopping-summery .price::before {
        content: "Price: ";
    }

    .shopping-summery .text-center::before {
        content: "Quantity: ";
    }

    .shopping-summery .action::before {
        content: "Remove: ";
    }

    .shopping-summery .action a {
        display: inline-block;
        margin-top: 5px;
    }
}

/* Cart totals responsiveness */
@media (max-width: 991px) {
    .cart-totals-container {
        text-align: center;
        padding: 20px;
    }

    .cart-totals-container .flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .cart-totals-container a.w-full {
        display: block;
    }
}

@media (max-width: 576px) {
    .cart-totals-container h2 {
        font-size: 1.5rem;
    }

    .cart-totals-container .flex {
        flex-direction: column;
        text-align: center;
    }

    .cart-totals-container .flex span {
        margin-bottom: 5px;
    }

    .cart-totals-container .flex div {
        text-align: center;
    }
}

@media (max-width: 767px) {
    .mt-50 {
        margin-top: 30px;
    }

    .mb-50 {
        margin-bottom: 30px;
    }
}
</style>



<section class="banner-area organic-breadcrumb">
    <div class="container">
        <div class="breadcrumb-banner d-flex flex-wrap align-items-center justify-content-end">
            <div class="col-first">
                <h1>Shopping Cart</h1>
                <nav class="d-flex align-items-center">
                    <a href="/">Home<span class="lnr lnr-arrow-right"></span></a>
                    <a href="/cart">Cart</a>
                </nav>
            </div>
        </div>
    </div>
</section>

<main class="main">
    <br><br>
    <section class="mt-50 mb-50">
        <div class="container">
            <div class="row">
                <div class="col-9">
                    <div class="table-responsive">
                        <table class="table shopping-summery text-center clean">
                            <thead>
                                <tr class="main-heading">
                                    <th scope="col">Image</th>
                                    <th scope="col">Name</th>
                                    <th scope="col">Price</th>
                                    <th scope="col">Quantity</th>
                                    <th scope="col">Remove</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (cartItems && cartItems.length > 0) { %>
                                    <% cartItems.forEach(function(item) { %>
                                        <tr id="cart-item-<%= item.product._id %>" data-product-id="<%= item.product._id %>">
                                            <td class="image product-thumbnail" data-title="Image">
                                                <img src="<%= item.product.productImage[0] %>" alt="#" />
                                            </td>
                                            <td class="product-des product-name" data-title="Name">
                                                <h5 class="product-name">
                                                    <a href="/productDetails?id=<%= item.product._id %>"><%= item.product.productName %></a>
                                                </h5>
                                                <p class="font-xs">
                                                    <%= item.product.category.name %><br />
                                                    <%= item.product.brand %>
                                                </p>
                                            </td>
                                            <td class="price" data-title="Price">
                                                ₹<span id="subTotal<%= item.product._id %>"><%= item.totalPrice %></span><br>
                                                <small class="text-muted text-nowrap">₹<span id="price<%= item.product._id %>"><%= item.product.salePrice %></span> / per item</small>
                                            </td>
                                            <td class="text-center" data-title="Stock">
                                                <div class="detail-qty border radius m-auto">
                                                    <div class="quantity-control">
                                                        <button class="btn btn-sm increment-button" data-product-id="<%= item.product._id %>" data-max-stock="<%= item.product.quantity %>">+</button>
                                                        <input class="quantity-input" id="cartProductQuantity<%= item.product._id %>" value="<%= item.quantity %>" style="width: 45px;" type="text" readonly>
                                                        <button class="btn btn-sm decrement-button" data-product-id="<%= item.product._id %>" data-max-stock="<%= item.product.quantity %>">-</button>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="action" data-title="Remove">
                                                <a class="btn btn-sm remove-item" href="#" data-product-id="<%= item.product._id %>">
                                                    <i class="fi-rs-trash">Remove</i>
                                                </a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center">
                                            <p class="lead mb-4">No item found in Cart</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-3">
                    <div class="cart-totals-container">
                        <h2>Cart Totals</h2>
                        <hr>
                        <div class="flex">
                            <span>Subtotal</span>
                            <span class="font-semibold">₹ <span id="grand-total"><%= grandTotal %></span></span>
                        </div>
                        <div class="flex">
                            <span>Coupon Discount</span>
                            <span class="font-semibold">(-) 00.00</span>
                        </div>
                        <div class="flex">
                            <span>Shipping</span>
                            <div class="text-right">
                                <span class="font-semibold">₹ 50.00</span>
                                <br>
                                <a href="#" onclick="viewShippingCharge()" class="text-blue text-sm">View shipping charge</a>
                            </div>
                        </div>
                        <div class="flex mb-4">
                            <span>Total</span>
                            <span class="font-semibold text-blue">₹ <span id="final-total"><%= Math.round(grandTotal)+50 %></span></span>
                        </div>
                        <a href="/checkout" class="w-full bg-yellow text-white py-2 px-2 rounded mb-4">Proceed To Checkout</a>
                        <br>
                        <a href="/shop" class="block text-center text-blue mt-3">Continue Shopping</a>
                        
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add event listeners to all increment buttons
        document.querySelectorAll('.increment-button').forEach(button => {
            button.addEventListener('click', function() {
                const productId = this.getAttribute('data-product-id');
                const maxStock = parseInt(this.getAttribute('data-max-stock'));
                updateQuantity(productId, 'increase', maxStock);
            });
        });

        // Add event listeners to all decrement buttons
        document.querySelectorAll('.decrement-button').forEach(button => {
            button.addEventListener('click', function() {
                const productId = this.getAttribute('data-product-id');
                const maxStock = parseInt(this.getAttribute('data-max-stock'));
                updateQuantity(productId, 'decrease', maxStock);
            });
        });

        // Add event listeners to all remove buttons
        document.querySelectorAll('.remove-item').forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const productId = this.getAttribute('data-product-id');
                confirmRemove(productId);
            });
        });

        // Function to update quantity without page reload
        function updateQuantity(productId, action, maxStock) {
            const quantityElement = document.getElementById(`cartProductQuantity${productId}`);
            const currentQuantity = parseInt(quantityElement.value);
            
            // Validate quantity changes client-side first
            if (action === 'increase') {
                if (currentQuantity >= 5) {
                    Swal.fire('Error', 'Maximum 5 quantity per user', 'error');
                    return;
                }
                if (currentQuantity >= maxStock) {
                    Swal.fire('Error', 'Stock limit exceeded', 'error');
                    return;
                }
            } else if (action === 'decrease' && currentQuantity <= 1) {
                confirmRemove(productId);
                return;
            }

            // Show loading indicator
            const cartItem = document.getElementById(`cart-item-${productId}`);
            if (cartItem) {
                cartItem.style.opacity = '0.6';
            }

            // Make AJAX request to update quantity
            $.ajax({
                url: '/changeQuantity',
                method: 'POST',
                data: { productId: productId, action: action },
                success: (response) => {
                    // Reset opacity
                    if (cartItem) {
                        cartItem.style.opacity = '1';
                    }

                    if (response.status) {
                        // Update quantity display
                        quantityElement.value = response.quantity;
                        
                        // Update subtotal for this item
                        const priceElement = document.getElementById(`price${productId}`);
                        const subtotalElement = document.getElementById(`subTotal${productId}`);
                        
                        if (priceElement && subtotalElement) {
                            const price = parseFloat(priceElement.textContent);
                            const newSubtotal = price * response.quantity;
                            subtotalElement.textContent = newSubtotal.toFixed(2);
                        }
                        
                        // Update cart totals
                        updateCartTotals();
                    } else {
                        Swal.fire('Error', response.message, 'error');
                    }
                },
                error: (error) => {
                    console.error("AJAX Error:", error);
                    if (cartItem) {
                        cartItem.style.opacity = '1';
                    }
                    Swal.fire('Error', 'An error occurred while updating the cart', 'error');
                }
            });
        }

        // Function to update cart totals
        function updateCartTotals() {
            let subtotal = 0;
            
            // Calculate subtotal from all items
            document.querySelectorAll('[id^="subTotal"]').forEach(element => {
                subtotal += parseFloat(element.textContent);
            });
            
            // Update subtotal display
            const grandTotalElement = document.getElementById('grand-total');
            if (grandTotalElement) {
                grandTotalElement.textContent = subtotal.toFixed(2);
            }
            
            // Update total (subtotal + shipping)
            const finalTotalElement = document.getElementById('final-total');
            if (finalTotalElement) {
                const total = Math.round(subtotal) + 50; // Adding shipping cost
                finalTotalElement.textContent = total.toFixed(2);
            }
        }

        // Function to confirm removal
        function confirmRemove(productId) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, remove it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    removeItem(productId);
                }
            });
        }

        // Function to remove item
        function removeItem(productId) {
            const cartItem = document.getElementById(`cart-item-${productId}`);
            if (cartItem) {
                cartItem.style.opacity = '0.6';
            }

            $.ajax({
                url: `/deleteItem?id=${productId}`,
                method: 'GET',
                success: (response) => {
                    if (response.status) {
                        // Remove the item from DOM
                        if (cartItem) {
                            cartItem.remove();
                        }
                        
                        // Update cart totals
                        updateCartTotals();
                        
                        // Check if cart is empty
                        const cartItems = document.querySelectorAll('[id^="cart-item-"]');
                        if (cartItems.length === 0) {
                            const tableBody = document.querySelector('.shopping-summery tbody');
                            if (tableBody) {
                                tableBody.innerHTML = `
                                    <tr>
                                        <td colspan="5" class="text-center">
                                            <p class="lead mb-4">No item found in Cart</p>
                                        </td>
                                    </tr>
                                `;
                            }
                        }
                        
                        Swal.fire('Removed!', response.message, 'success');
                    } else {
                        if (cartItem) {
                            cartItem.style.opacity = '1';
                        }
                        Swal.fire('Error', response.message, 'error');
                    }
                },
                error: (error) => {
                    console.error("AJAX Error:", error);
                    if (cartItem) {
                        cartItem.style.opacity = '1';
                    }
                    Swal.fire('Error', 'There was an error removing the item from the cart', 'error');
                }
            });
        }
    });

    function viewShippingCharge() {
        Swal.fire({
            title: 'Shipping Charge',
            text: 'Shipping charge is ₹ 50.00 For All Orders',
            icon: 'info',
            confirmButtonText: 'OK'
        });
    }
</script>

<%- include("../../views/partials/user/footer") %>
